# MangaSama — Environment Configuration
# Copy to `.env` and customize.

# --- Core ---
APP_NAME=MangaSama
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DEBUG=false

# --- Paths ---
# DATA_DIR is where the SQLite DB and library folders live.
DATA_DIR=/data
# CONFIG_DIR is where the YAML configs and cookie caches live.
CONFIG_DIR=/config
# INSIDE_DATA_DIR: subdirectory for the SQLite file.
DB_FILENAME=mangasama.db
# INSIDE_DATA_DIR: where CBZ files are written by default if a library's root_path is relative.
DOWNLOADS_DIR=downloads

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000

# --- Auth (optional, see README §Auth) ---
AUTH_ENABLED=false
ADMIN_PASSWORD=

# --- Cloudflare bypass ---
# Options: unset (just raise BlockedByCloudflare) | playwright | flaresolverr
CLOUDFLARE_SOLVER=
FLARESOLVERR_URL=http://flaresolverr:8191/v1

# --- Scraper behavior ---
DEFAULT_RATE_LIMIT_RPM=30
SCRAPER_CONCURRENCY=4
USER_AGENT=MangaSama/0.1 (+https://github.com/mangasama/mangasama)

# --- AniList (GraphQL) ---
ANILIST_URL=https://graphql.anilist.co
ANILIST_RATE_LIMIT_RPM=30

# --- MangaDex (REST) ---
MANGADEX_URL=https://api.mangadex.org
MANGADEX_RATE_LIMIT_RPM=40

# --- Google Books (dormant in v1) ---
GOOGLE_BOOKS_URL=https://www.googleapis.com/books/v1
GOOGLE_BOOKS_API_KEY=
GOOGLE_BOOKS_ENABLED=false

# --- Optional providers (set to "true" to enable) ---
SCRAPER_MANGAPARK_ENABLED=false
SCRAPER_BATO_ENABLED=true
SCRAPER_MANGAKAKALOT_ENABLED=true

# --- Scheduler ---
# follow_check runs every N minutes.
SCHEDULER_FOLLOW_INTERVAL_MIN=15
# domain_health runs every N minutes.
SCHEDULER_DOMAIN_HEALTH_MIN=15
# cleanup_provider_jobs runs daily; deletes jobs older than N days.
SCHEDULER_JOB_RETENTION_DAYS=30

# --- Download workers ---
DOWNLOAD_WORKER_COUNT=3
DOWNLOAD_QUEUE_SIZE=200

# --- Backup ---
BACKUP_ENABLED=false
BACKUP_RETENTION_DAYS=7

# --- Frontend build (used by Docker multi-stage) ---
FRONTEND_OUT_DIR=app/web
