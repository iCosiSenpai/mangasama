# MangaSama — Bootstrap Environment Configuration
#
# Most settings are now managed from the web UI and stored in
# /config/settings.yaml. This file only controls values needed before the app
# can read that file (or values you prefer to keep in the environment).
#
# Copy to `.env` and customize only what you need.

# --- Core ---
APP_NAME=MangaSama
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DEBUG=false

# --- Paths ---
# DATA_DIR is where the SQLite DB, covers and default downloads live.
DATA_DIR=/data
# CONFIG_DIR is where YAML configs, runtime settings, cookie caches and backups live.
CONFIG_DIR=/config
# INSIDE_DATA_DIR: subdirectory for the SQLite file.
DB_FILENAME=mangasama.db
# INSIDE_DATA_DIR: where CBZ files are written when a library root is relative.
DOWNLOADS_DIR=downloads

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000

# --- CORS / proxy ---
# Comma-separated allowed origins for the dev frontend (production is same-origin).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Client IPs uvicorn trusts for X-Forwarded-* headers. Tighten to your reverse
# proxy's address/CIDR in production instead of the permissive default "*".
FORWARDED_ALLOW_IPS=*

# --- Frontend build (used by Docker multi-stage) ---
FRONTEND_OUT_DIR=app/web
